// ==================== PELAYANAN SURAT DESA ====================

enum SuratStatus {
  DRAFT
  MENUNGGU_PROSES
  DALAM_PROSES
  MENUNGGU_APPROVAL
  DITOLAK_OPERATOR
  DITOLAK_KADES
  DISETUJUI
  DICETAK
  DIBATALKAN
  DIARSIPKAN
}

enum SuratLogAksi {
  AJUKAN
  PROSES
  APPROVE
  REJECT
  CETAK
  BATAL
  ARSIP
  UPDATE
}

enum FormatBulan {
  ROMAWI
  ANGKA
  TANPA
}

enum KategoriSurat {
  KEPENDUDUKAN
  PENGANTAR
  KETERANGAN
  PERNYATAAN
  TANAH_PROPERTI
  KEUANGAN
  LEMBAGA
}

enum TingkatApproval {
  LANGSUNG_PROSES
  PERLU_APPROVAL
}

model SuratJenis {
  id              String          @id @default(cuid())
  kode            String          @unique
  nama            String
  kategori        KategoriSurat
  tingkatApproval TingkatApproval  @default(LANGSUNG_PROSES)
  deskripsi       String?
  persyaratan     String?
  fieldTemplate   String?
  isActive        Boolean         @default(true)
  urutan          Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  desaId          String
  desa            Desa            @relation(fields: [desaId], references: [id], onDelete: Cascade)
  surat           Surat[]
  suratTemplate   SuratTemplate?
  nomorSurat      NomorSurat[]

  @@index([desaId])
  @@index([kategori])
  @@index([kode])
}

model SuratTemplate {
  id              String          @id @default(cuid())
  nama            String
  jenisSuratId    String          @unique
  kontenHTML      String
  kontenCSS       String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  jenisSurat      SuratJenis      @relation(fields: [jenisSuratId], references: [id], onDelete: Cascade)

  @@index([jenisSuratId])
}

model SuratKonfigurasi {
  id                String        @id @default(cuid())
  desaId            String        @unique
  formatNomorSurat  String        @default("{nomor}/{kodeDesa}/{bulan}/{tahun}")
  digitPadding      Int           @default(3)
  formatBulan       FormatBulan   @default(ROMAWI)
  resetNomorPer     String        @default("PER_TAHUN")
  formatNomorRegister String      @default("{nomor}/{kodeDesa}")
  digitPaddingReg   Int           @default(4)
  kodeDesaSurat     String
  kepalaDesaNama    String?
  kepalaDesaNIP     String?
  sekretarisNama    String?
  sekretarisNIP     String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  desa              Desa          @relation(fields: [desaId], references: [id], onDelete: Cascade)
}

model NomorSurat {
  id              String    @id @default(cuid())
  desaId          String
  jenisSuratId    String
  tahun           Int
  bulan           Int       @default(0)
  nomorTerakhir   Int       @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  desa            Desa      @relation(fields: [desaId], references: [id], onDelete: Cascade)
  jenisSurat      SuratJenis @relation(fields: [jenisSuratId], references: [id], onDelete: Cascade)

  @@unique([desaId, jenisSuratId, tahun, bulan])
  @@index([desaId])
  @@index([jenisSuratId])
}

model NomorRegister {
  id              String    @id @default(cuid())
  desaId          String
  tahun           Int
  nomorTerakhir   Int       @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  desa            Desa      @relation(fields: [desaId], references: [id], onDelete: Cascade)

  @@unique([desaId, tahun])
  @@index([desaId])
}

model Surat {
  id                String      @id @default(cuid())
  desaId            String
  desa              Desa        @relation(fields: [desaId], references: [id], onDelete: Cascade)
  jenisSuratId      String
  jenisSurat        SuratJenis  @relation(fields: [jenisSuratId], references: [id])
  pemohonId         String?
  pemohon           Penduduk?   @relation(fields: [pemohonId], references: [id])
  operatorId        String?
  operator          User?       @relation("OperatorSurat", fields: [operatorId], references: [id])
  approverId        String?
  approver          User?       @relation("ApproverSurat", fields: [approverId], references: [id])
  nomorSurat         String?
  nomorIndex         Int?
  nomorRegister      Int?
  nomorRegisterFmt   String?
  pemohonNama       String
  pemohonNIK        String?
  pemohonAlamat     String?
  pemohonRT          String?
  pemohonRW          String?
  pemohonDusun       String?
  pemohonTelepon     String?
  isiSurat          String
  status            SuratStatus @default(DRAFT)
  tanggalAjukan     DateTime?
  tanggalProses     DateTime?
  tanggalSelesai    DateTime?
  catatanOperator   String?
  catatanApprover   String?
  alasanDitolak     String?
  filePDF           String?
  fileQRCode        String?
  dokumenPendukung  String?
  dicetakPada       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  log               SuratLog[]

  @@index([desaId])
  @@index([jenisSuratId])
  @@index([pemohonId])
  @@index([operatorId])
  @@index([approverId])
  @@index([status])
  @@index([nomorSurat])
  @@index([nomorRegister])
  @@index([tanggalAjukan])
  @@index([desaId, status])
  @@index([desaId, createdAt])
}

model SuratLog {
  id              String        @id @default(cuid())
  suratId         String
  surat           Surat         @relation(fields: [suratId], references: [id], onDelete: Cascade)
  aksi            SuratLogAksi
  userId          String?
  userName        String
  keterangan      String?
  dataSebelum     String?
  dataSesudah      String?
  ipAddress       String?
  createdAt       DateTime      @default(now())

  @@index([suratId])
  @@index([aksi])
  @@index([createdAt])
}

// Koperasi (Koperasi Merah Putih)
model Koperasi {
  id                String            @id @default(cuid())
  
  // Relasi ke Desa
  desaId            String
